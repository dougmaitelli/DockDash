# DockDash Configuration
# Copy this file to .env and fill in the values you want to override.
# All variables are optional — defaults are shown below.

# Server
PORT=3001
DB_PATH=./dockdash.db
LOCALE=en

# Docker
# DOCKER_HOSTS=unix:///var/run/docker.sock
# The local socket is auto-detected; add remote hosts here:
# DOCKER_HOSTS=tcp://192.168.1.10:2375,tcp://192.168.1.11:2375

# Network scanning
NETWORK_CIDRS=192.168.1.0/24
SCAN_PORTS=22,80,443,3000,3001,3306,5432,6379,8080,8443,9090,27017

# Intervals (milliseconds)
REFRESH_INTERVAL=30000
HEALTH_CHECK_INTERVAL=30000
UPDATE_CHECK_INTERVAL=3600000
HEALTH_HISTORY_TTL_DAYS=30

# GitHub — increases API rate limit when fetching changelogs (optional)
# GITHUB_TOKEN=ghp_...

# Apprise notifications (optional)
# APPRISE_URL=http://apprise:8000/notify/myconfig
# APPRISE_TAGS=admin
# APPRISE_URLS=slack://tokenA/tokenB/tokenC/#channel

# Feature flags — set to "true" to disable
# DISABLE_CONTAINER_CONTROLS=true
# DISABLE_FILE_EXPLORER=true
# DISABLE_TERMINAL=true

# OIDC authentication (optional — app is unsecured when these are not set)
# OIDC_ISSUER=https://auth.example.com/realms/myrealm
# OIDC_CLIENT_ID=dockdash
# OIDC_CLIENT_SECRET=change-me
# OIDC_REDIRECT_URI=https://dockdash.example.com/auth/callback  # auto-detected if not set
# OIDC_SCOPES=openid profile email
# SESSION_SECRET=change-me-to-a-long-random-string
# SESSION_MAX_AGE=28800000  # milliseconds, default 8 hours
