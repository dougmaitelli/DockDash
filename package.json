{
  "name": "dockdash",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev:server": "tsx --watch --tsconfig tsconfig.server.json src/server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:client\"",
    "dev:mock": "concurrently \"tsx --watch --tsconfig tsconfig.server.json src/server/mockEntry.ts\" \"yarn dev:client\"",
    "build": "esbuild src/server/index.ts --bundle --platform=node --format=esm --outfile=dist/server/index.js --packages=external --alias:@shared=./src/shared --sourcemap && mkdir -p dist/server/i18n/locales && cp src/server/i18n/locales/*.json dist/server/i18n/locales/ && vite build",
    "start": "node dist/server/index.js",
    "lint": "eslint src/ scripts/ *.ts *.js && prettier --check \"src/\" \"scripts/\" \"*.{js,ts,json}\"",
    "lint:fix": "eslint --fix src/ scripts/ *.ts *.js && prettier --write \"src/\" \"scripts/\" \"*.{js,ts,json}\"",
    "typecheck": "tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "yarn test -- --coverage",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "screenshots": "tsx scripts/take-screenshots.ts",
    "screenshots:docker": "sh scripts/screenshots-docker.sh"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.10.0",
    "better-sqlite3-session-store": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dockerode": "^5.0.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.25.0",
    "openid-client": "^6.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-emoji": "^5.0.2",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "form-data": "^4.0.6",
    "protobufjs": "^7.6.5",
    "vite": "8.1.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.9"
  }
}
