{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@shared": ["./src/shared-types/index.js"],
      "@shared/*": ["./src/shared-types/*.js"]
    }
  },
  "include": ["src/server/**/*", "src/shared-types/**/*"],
  "exclude": ["node_modules"]
}
